{
  "name": "triviamore",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.1",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "infisical run -- vite dev --port 3000",
    "dev:staging": "infisical run --env=staging -- vite dev --port 3000",
    "dev:prod": "infisical run --env=prod -- vite dev --port 3000",
    "dev:no-secrets": "vite dev --port 3000",
    "build": "vite build",
    "build:dev": "infisical run -- vite build",
    "start": "node .output/server/index.mjs",
    "preview": "infisical run -- vite preview",
    "test": "vitest run",
    "db:seed": "infisical run -- pnpm tsx supabase/scripts/seed.ts",
"generate:sitemap": "pnpm tsx scripts/generate-sitemap.ts",
    "generate:sitemap:dev": "infisical run -- pnpm generate:sitemap",
    "postbuild": "pnpm generate:sitemap"
  },
  "dependencies": {
