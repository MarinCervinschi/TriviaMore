# Copy this file to `.env` and fill in the values, then run `pnpm dev:no-secrets`.
# Run `supabase status` to read your local Supabase credentials.

# Supabase (required) — values come from `supabase status`
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# App URLs (required for OAuth redirects and canonical links)
VITE_APP_URL=http://localhost:3000
VITE_SITE_URL=http://localhost:3000

# OAuth providers (optional — email/password auth works without them)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
